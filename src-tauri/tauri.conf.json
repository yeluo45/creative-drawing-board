{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Creative Drawing Board",
  "version": "1.1.0",
  "identifier": "com.yeluo45.creative-drawing-board",
  "build": {
    "frontendDist": "../",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Creative Drawing Board",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "fs": {
      "all": true,
      "scope": ["**"]
    },
    "notification": {
      "all": true
    },
    "clipboard-manager": {
      "all": true
    },
    "dialog": {
      "all": true
    }
  }
}